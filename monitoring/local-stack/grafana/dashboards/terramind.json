{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "TerraMind Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["terramind", "drone-swarm"],
  "title": "TerraMind — Swarm Operations",
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Drones",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "targets": [{ "expr": "terramind_active_drones", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Active Threats",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [{ "expr": "terramind_active_threats", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "Neutralized (session)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "targets": [{ "expr": "terramind_neutralized_total", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "AI Engine",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "value", "options": { "1": { "text": "ONLINE", "color": "green" }, "0": { "text": "DEGRADED", "color": "red" } } } ],
        "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "targets": [{ "expr": "terramind_ai_engine_online", "refId": "A" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Active Threats over time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "terramind_active_threats", "refId": "A", "legendFormat": "active threats" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "AI Scan Rate (per source)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "sum by (source) (rate(terramind_ai_scans_total[5m]))", "refId": "A", "legendFormat": "{{source}}" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "AI Inference Latency (p90, seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "histogram_quantile(0.9, sum(rate(terramind_ai_latency_seconds_bucket[5m])) by (le, source))", "refId": "A", "legendFormat": "p90 {{source}}" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Threats Injected by Priority",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "sum by (priority) (rate(terramind_threats_injected_total[10m]))", "refId": "A", "legendFormat": "{{priority}}" }]
    }
  ]
}
