# ─── secrets — NEVER commit ───────────────────────────────────────────────
.env
**/.env
**/.env.local
*.local
# keep templates
!**/.env.example

# ─── python ───────────────────────────────────────────────────────────────
**/.venv/
**/__pycache__/
*.pyc
*.pyo
*.db
*.sqlite3

# ─── node / next ──────────────────────────────────────────────────────────
**/node_modules/
**/.next/
**/out/
**/build/
*.tsbuildinfo
next-env.d.ts

# ─── terraform ────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
# keep the lock file committed (.terraform.lock.hcl)

# ─── misc ─────────────────────────────────────────────────────────────────
.DS_Store
*.log
.idea/
.vscode/
